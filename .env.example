# ============================================================
# .env.local — copy this file and fill in your values
# NEVER commit the filled version to git
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — server-side only, bypasses RLS
# Keep this out of any client-side code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── API Auth ──────────────────────────────────────────────────
# Must match API_KEY in your NT8 addon / NinjaTrader.ini
# Generate a strong random value: openssl rand -hex 32
API_KEY=change-me-generate-a-strong-key

# ── Optional: Alert channels ──────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
